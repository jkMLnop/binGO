# binGO-CLI Environment Configuration
# Copy this file to .env and fill in real values before running docker-compose.
#
#   cp .env.example .env
#
# The .env file is gitignored — never commit real credentials.

# ─────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────
# Admin username for the Grafana UI.
GRAFANA_USER=admin

# Admin password for the Grafana UI.
# Use a strong password in any shared or production environment.
GRAFANA_PASSWORD=change_me_in_production

# ─────────────────────────────────────────────
# Bingo Server
# ─────────────────────────────────────────────
# Secret key required to authenticate admin API requests (POST /api/admin/...).
# Must match the key used by any admin clients or CI scripts.
# Generate a strong key: openssl rand -hex 32
ADMIN_API_KEY=change_me_in_production

# Log verbosity level. One of: debug, info, warn, error
LOG_LEVEL=info
