# binGO-CLI Environment Configuration
# Copy this file to .env and fill in real values before running docker-compose.
#
#   cp .env.example .env
#
# The .env file is gitignored — never commit real credentials.

# ─────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────
# Admin username for the Grafana UI.
GRAFANA_USER=admin

# Admin password for the Grafana UI.
# Use a strong password in any shared or production environment.
GRAFANA_PASSWORD=change_me_in_production

# ─────────────────────────────────────────────
# Bingo Server
# ─────────────────────────────────────────────
# Secret key required to authenticate admin API requests (POST /api/admin/...).
# Must match the key used by any admin clients or CI scripts.
# Generate a strong key: openssl rand -hex 32
ADMIN_API_KEY=change_me_in_production

# Bearer token protecting the /metrics endpoint from public scraping.
# Required by Grafana Cloud scrape jobs on staging/production.
# Leave unset for local dev (docker-compose) — endpoint stays open when empty.
# Generate: openssl rand -hex 32
# METRICS_AUTH_TOKEN=

# Log verbosity level. One of: debug, info, warn, error
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Rate Limiting (optional, defaults below)
# ─────────────────────────────────────────────
# Maximum WebSocket connections allowed from a single IP address.
# Default: 5 (production). Increase for load testing: 50, 100, etc.
# MAX_CONNS_PER_IP=5

# Maximum failed game-code guesses per IP within CODE_GUESS_WINDOW.
# Default: 5. Increase for load testing or aggressive retry scenarios.
# CODE_GUESS_PER_WINDOW=5
