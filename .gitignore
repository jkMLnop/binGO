/bin
/bingo
/binGO
/binGO-*

# Log files
app.log
*.log

# Dagger compiled binary
/dagger/dagger

bingo_demo.mp4

# LLM experiment sweep output (raw data; results baked into code constants)
docs/llm-experiments/

