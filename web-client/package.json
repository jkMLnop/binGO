{
  "name": "bingo-web-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:host-flow": "playwright test e2e/host-flow-smoke.spec.js --config=playwright.config.cjs",
    "smoke:staging": "STAGING_BASE_URL=https://bingo-server-staging.fly.dev playwright test e2e/host-flow-smoke.spec.js --config=playwright.config.cjs",
    "smoke:dev": "SMOKE_BASE_URL=http://localhost:8080 playwright test e2e/host-flow-smoke.spec.js --config=playwright.config.cjs",
    "smoke:prod": "PROD_BASE_URL=https://bingo-server.fly.dev playwright test e2e/prod-readonly-smoke.spec.js --config=playwright.config.cjs",
    "smoke:all": "sh -c 'set +e; npm run smoke:dev; dev=$?; npm run smoke:staging; staging=$?; npm run smoke:prod; prod=$?; echo \"smoke summary: dev=$dev staging=$staging prod=$prod\"; if [ $dev -ne 0 ] || [ $staging -ne 0 ] || [ $prod -ne 0 ]; then exit 1; fi'",
    "smoke:all:remote": "sh -c 'set +e; npm run smoke:staging; staging=$?; npm run smoke:prod; prod=$?; echo \"smoke summary: staging=$staging prod=$prod\"; if [ $staging -ne 0 ] || [ $prod -ne 0 ]; then exit 1; fi'"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^1.6.1"
  }
}
